/**
 * Implements hook_mail().
 */
function campaign_winner_selection_mail($key, &$message, $params) {
  switch ($key) {
    case 'winner_notification':
      $message['subject'] = $params['subject'];
      $message['body'][] = $params['message'];
      break;
  }
}

/**
 * Select the winners from submissions and mark them as winners.
 *
 * @param string $campaign
 *   The ID of the webform.
 * @param string $event_type
 *   The Event Type.
 * @param string $country
 *   Country selected.
 * @param int $count
 *   The number of winners to select.
 *
 * @return array|bool
 *   An array of winner emails, or FALSE if no winners are available.
 */
function _campaign_winner_selection_get_winners($campaign, $event_type, $country, $count) {
  $non_winners = _campaign_winner_selection_filter_non_winners($campaign, $country);

  if (empty($non_winners)) {
    \Drupal::messenger()->addError(t('No users available to select'));
    return FALSE;
  }
  $selected_submissions = _campaign_winner_selection_select_random_submissions($non_winners, $count);

  if ($event_type == 'voucher_code_winners') {
    // Get random coupon codes.
    $coupon_codes = _campaign_winner_selection_get_coupon_codes($count, $country);
    if (!empty($coupon_codes)) {
      // Update winners with coupon codes selected.
      return _campaign_winner_selection_update_winners($selected_submissions, $event_type, $coupon_codes);
    }
  } else {
    return _campaign_winner_selection_update_winners($selected_submissions, $event_type, '');
  }
}

/**
 * Selects random submissions from a list.
 *
 * @param array $submissions
 *   An array of webform submission entities.
 * @param int $count
 *   The number of submissions to select.
 *
 * @return array
 *   An array of randomly selected webform submission entities.
 */
function _campaign_winner_selection_select_random_submissions(array $submissions, $count) {
  $submission_ids = array_map(function ($submission) {
    return $submission->id();
  }, $submissions);

  if (count($submission_ids) < $count) {
    $count = count($submission_ids);
  }

  $selected_ids = (array) array_rand(array_flip($submission_ids), $count);

  return array_filter($submissions, function ($submission) use ($selected_ids) {
    return in_array($submission->id(), $selected_ids);
  });
}

/**
 * Retrieves winner submissions based on campaign, event type, and country.
 *
 * @param string $campaign
 *   The campaign ID.
 * @param string $event_type
 *   The event type to filter submissions.
 * @param string $country
 *   The country to filter submissions.
 *
 * @return array
 *   An array of webform submissions matching the specified criteria.
 */
function _campaign_winner_selection_get_winner_submissions($campaign, $event_type, $country) {
  $submissions = _campaign_winner_selection_get_submissions($campaign);
  return array_filter($submissions, function ($submission) use ($event_type, $country) {
    return ($submission->getElementData('winner') == 1 &&
      $submission->getElementData('event_type') == $event_type &&
      $submission->getElementData('country') == $country &&
      $submission->getElementData('email_sent') != 1 
    );
  });
}

/**
 * Filters submissions to exclude winners.
 *
 * @param string $campaign_id
 *   The ID of the webform.
 *
 * @return array
 *   An array of non-winner webform submission entities.
 */
function _campaign_winner_selection_filter_non_winners($campaign_id, $country) {
  $submissions = _campaign_winner_selection_get_submissions($campaign_id);
  return array_filter($submissions, function ($submission) use ($country) {
    return ($submission->getElementData('winner') != 1
      && $submission->getElementData('country') == $country
    );
  });
}

/**
 * Updates the winner status of given submissions.
 *
 * @param array $submissions
 *   An array of webform submission entities.
 */
function _campaign_winner_selection_update_winners(array $submissions, $event_type, $coupon_codes) {
  foreach (array_values($submissions) as $key => $submission) {
    $data = $submission->getData();
    $country = $data['country'];
    if($country == 'UAE'){
      $voucher_url = 'https://www.amazon.ae/s?k=purina&crid=LEE1T4Y7IBL0&sprefix=purina%2Caps%2C350&ref=nb_sb_ss_ts-doa-p_2_6';
    }else{
      $voucher_url = 'https://www.amazon.sa/s?k=Purina&crid=O37M6U034I93&sprefix=purina%2Caps%2C209&ref=nb_sb_noss_1';
    }
    $data['winner'] = 1;
    $data['event_type'] = $event_type;
    $data['voucher_code'] = $coupon_codes[$key] ?? '';
    $data['voucher_url'] = $voucher_url;
    $submission->setData($data);
    $submission->save();
  }
  return count($submissions) ?? [];
}


/**
 * Updates the winner's email status
 *
 * @param array $submissions
 *   An array of webform submission entities.
 */
function _campaign_winner_selection_update_winners_email(WebformSubmissionInterface $submission) {
    $data = $submission->getData();
    $data['email_sent'] = 1;
    $submission->setData($data);
    if($submission->save()){
      return TRUE;
    }
    
}

/**
 * Helper function to get random terms from a vocabulary and update their field.
 *
 * @param int $count
 *   The number of terms to retrieve and update.
 *
 * @return array|bool
 *   An array of selected term labels or FALSE on failure.
 */
function _campaign_winner_selection_get_coupon_codes($count, $country) {
  $field_name = 'field_selected';
  $field_country = 'field_country';
  $vocabulary = 'coupons';

  // Load terms from the vocabulary.
  $terms = \Drupal::entityTypeManager()->getStorage('taxonomy_term')->loadTree($vocabulary);

  // Filter terms where field_selected is not equal to 1.
  $filtered_terms = array_filter($terms, function ($term) use ($field_name, $field_country, $country) {
    $term_entity = \Drupal::entityTypeManager()->getStorage('taxonomy_term')->load($term->tid);
    if ($term_entity && !$term_entity->get($field_name)->isEmpty() && !$term_entity->get($field_country)->isEmpty()){
      return ($term_entity->get($field_name)->value != 1
     && $term_entity->get($field_country)->value == $country);
    }
  });

  // Handle cases where there are insufficient terms.
  if (empty($filtered_terms)) {
    \Drupal::messenger()->addError(t('No Coupon codes available!'));
    return FALSE;
  }
  if (count($filtered_terms) < $count) {
    \Drupal::messenger()->addError(t('Not enough Coupon codes available with the selected count.'));
    return FALSE;
  }

  // Randomly select terms.
  $filtered_tids = array_column($filtered_terms, 'tid');
  $selected_tids = array_rand(array_flip($filtered_tids), $count);
  $selected_tids = (array) $selected_tids;

  // Update selected terms and prepare return values.
  $term_labels = [];
  foreach ($selected_tids as $tid) {
    $term_entity = \Drupal::entityTypeManager()->getStorage('taxonomy_term')->load($tid);
    if ($term_entity) {
      $term_labels[] = $term_entity->label();
      $term_entity->set($field_name, 1);
      $term_entity->set($field_country, $country);
      $term_entity->save();
    }
  }
  return $term_labels;
}

/**
 * Retrieves a unique list of countries from submissions of a specific campaign.
 *
 * @return array
 *   An associative array of country names.
 */
function _campaign_winner_selection_get_country_list() {
  $campaign_id = 'campaign_contest';
  $submissions = _campaign_winner_selection_get_submissions($campaign_id);
  $country_list = [];
  foreach ($submissions as $submission) {
    $country_name = $submission->getElementData('country');
    $country_list[$country_name] = $country_name;
  }
  return array_unique($country_list);
}

/**
 * Retrieves webform submissions for a specific campaign.
 *
 * @param string $campaign_id
 *   The ID of the webform representing the campaign.
 *
 * @return \Drupal\webform\Entity\WebformSubmission[]
 *   An array of webform submission entities matching the given campaign ID.
 */
function _campaign_winner_selection_get_submissions($campaign_id) {
  $query = \Drupal::entityQuery('webform_submission')
    ->condition('webform_id', $campaign_id)
    ->accessCheck(TRUE)
    ->execute();
  return array_map([WebformSubmission::class, 'load'], array_values($query));
}
