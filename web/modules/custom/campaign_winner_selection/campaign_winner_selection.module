<?php

/**
 * @file
 * Primary module hooks for campaign_winner_selection module.
 */

use Drupal\taxonomy\Entity\Term;
use Drupal\webform\Entity\WebformSubmission;
use Drupal\webform\WebformSubmissionInterface;

/**
 * Implements hook_webform_submission_insert().
 */
function campaign_winner_selection_webform_submission_insert(WebformSubmissionInterface $submission) {
  // Load the submitted data.
  $data = $submission->getData();
  $webform_id = $submission->getWebform()->id();

  // Process only for the coupon code upload webform.
  if ($webform_id == 'campaign_upload_coupon_codes') {
    // Assuming coupons_csv' are the fields in the webform.
    // managed_file fields return an array of file IDs.
    $coupons_file_id = $data['coupon_codes'];

    // Load file entities.
    $coupons_file = \Drupal::entityTypeManager()->getStorage('file')->load($coupons_file_id);

    // Get the file URIs.
    $coupons_file_uri = $coupons_file->getFileUri();

    // Get the absolute file paths.
    $coupons_file_path = \Drupal::service('file_system')->realpath($coupons_file_uri);

    // Parse the CSV files.
    $coupons = _campaign_winner_selection_parse_csv($coupons_file_path);

    // Save coupons as taxonomy terms.
    if (!empty($coupons)) {
      foreach ($coupons as $coupon) {
        // Check if the term already exists.
        $existing_terms = \Drupal::entityTypeManager()->getStorage('taxonomy_term')->loadByProperties([
          'vid' => 'coupons',
          'name' => $coupon[1],
          'field_country' => $coupon[2],
        ]);
        if (empty($existing_terms)) {
          $terms = Term::create([
            'vid' => 'coupons',
            'name' => $coupon[1],
            'field_country' => $coupon[2],
          ]);
          $terms->save();
        } else {
          \Drupal::logger('campaign_winner_selection')->error('Coupon code @coupon alredy exists', ['@coupon' => $coupon[1]]);
        }
      }
    }
  }
  // Process users csv and create webform submission.
  elseif ($webform_id == 'campaign_upload_users') {
    // Assuming users are the fields in the webform.
    // managed_file fields return an array of file IDs.
    $users_file_id = $data['users'];

    // Load file entities.
    $users_file = \Drupal::entityTypeManager()->getStorage('file')->load($users_file_id);

    // Get the file URIs.
    $users_file_uri = $users_file->getFileUri();

    // Get the absolute file paths.
    $users_file_path = \Drupal::service('file_system')->realpath($users_file_uri);

    // Parse the CSV files.
    $users = _campaign_winner_selection_parse_csv($users_file_path);

    // Save users in webform as submissions.
    if (!empty($users)) {
      foreach ($users as $user) {
        // Assuming email is the third field in the CSV.
        $email = $user[2];

        if (empty($email)) {
          \Drupal::messenger()->addError(t('Unable to parse the csv file.'));
          return FALSE;
        }

        // Load all submissions for the webform.
        $existing_submissions = \Drupal::entityTypeManager()
          ->getStorage('webform_submission')
          ->loadByProperties(['webform_id' => 'campaign_contest']);

        $email_exists = FALSE;

        // Check if the email already exists in the submissions.
        foreach ($existing_submissions as $existing_submission) {
          $existing_data = $existing_submission->getData();
          if (isset($existing_data['email']) && $existing_data['email'] === $email) {
            $email_exists = TRUE;
            break;
          }
        }
        if (!$email_exists) {
          $submission_data = [
            // Assuming first_name is the first field in the CSV.
            'first_name' => $user[0],
            'last_name' => $user[1],
            'email' => $user[2],
            'country' => $user[3],
            'phone_number' => $user[4],
          ];

          // Create the webform submission.
          $webform_submission = WebformSubmission::create([
            'webform_id' => 'campaign_contest',
            'data' => $submission_data,
          ]);

          // Save the submission.
          if ($webform_submission->save()) {
            \Drupal::logger('campaign_winner_selection')->notice('Submission successfully added for @name.', ['@name' => $user[0]]);
          }
        } else {
          \Drupal::logger('campaign_winner_selection')->notice('Submission already exists for @name.', ['@name' => $user[0]]);
        }
      }
      \Drupal::messenger()->addStatus(t('Users imported Successfully'));
    }
  }
}

/**
 * Parses a CSV file and returns the data as an array.
 */
function _campaign_winner_selection_parse_csv($csv_file) {
  $parsed_data = [];
  $row = 0;
  if (($handle = fopen($csv_file, "r")) !== FALSE) {
    while (($data = fgetcsv($handle, 1000, ",")) !== FALSE) {
      // Skip the first row (header row).
      if ($row == 0) {
        $row++;
        continue;
      }
      $parsed_data[] = $data;
    }
    fclose($handle);
  }
  return $parsed_data;
}

