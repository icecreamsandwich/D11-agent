<?php

declare(strict_types=1);

/**
 * @file
 * Install, update and uninstall functions for the Site Page Builder module.
 *
 * hook_install() performs three actions:
 *  1. Enables Layout Builder with per-node overrides on the "page" content type.
 *  2. Programmatically builds the Layout Builder sections for /about-us.
 *  3. Programmatically builds the Layout Builder sections for /contact-us.
 */

use Drupal\Core\Entity\Entity\EntityViewDisplay;
use Drupal\layout_builder\Entity\LayoutBuilderEntityViewDisplay;
use Drupal\layout_builder\Section;
use Drupal\layout_builder\SectionComponent;

/**
 * Implements hook_install().
 */
function site_page_builder_install(): void {
  _site_page_builder_enable_layout_builder_on_page();
  _site_page_builder_setup_about_us_page();
  _site_page_builder_setup_contact_us_page();
}

// ---------------------------------------------------------------------------
// Internal helpers
// ---------------------------------------------------------------------------

/**
 * Enables Layout Builder with per-node overrides on the basic page type.
 */
function _site_page_builder_enable_layout_builder_on_page(): void {
  $display = EntityViewDisplay::load('node.page.default');

  if (!$display) {
    \Drupal::logger('site_page_builder')->error(
      'Could not load entity view display node.page.default — Layout Builder not enabled.'
    );
    return;
  }

  if (!($display instanceof LayoutBuilderEntityViewDisplay)) {
    \Drupal::logger('site_page_builder')->error(
      'node.page.default is not a LayoutBuilderEntityViewDisplay — is layout_builder enabled?'
    );
    return;
  }

  if ($display->isLayoutBuilderEnabled()) {
    \Drupal::logger('site_page_builder')->info(
      'Layout Builder already enabled on node.page.default — skipping.'
    );
    return;
  }

  $display->enableLayoutBuilder()->setOverridable(TRUE)->save();

  \Drupal::logger('site_page_builder')->info(
    'Layout Builder enabled on node.page.default with per-node overrides.'
  );
}

/**
 * Finds and returns the node for a given path alias.
 *
 * Falls back to searching menu_link_content entities by title if no alias
 * is found (handles sites where path aliases haven't been configured yet).
 *
 * @param string $alias
 *   The URL alias, e.g. '/about-us'.
 * @param string $menu_title
 *   Optional fallback menu link title to search by.
 *
 * @return \Drupal\node\NodeInterface|null
 *   The node, or NULL if not found.
 */
function _site_page_builder_get_node_from_alias(string $alias, string $menu_title = ''): ?\Drupal\node\NodeInterface {
  /** @var \Drupal\path_alias\AliasManagerInterface $alias_manager */
  $alias_manager = \Drupal::service('path_alias.manager');
  $system_path = $alias_manager->getPathByAlias($alias);

  if ($system_path !== $alias) {
    // Alias found — extract NID.
    $parts = explode('/', trim($system_path, '/'));
    if (count($parts) === 2 && $parts[0] === 'node' && ctype_digit($parts[1])) {
      return \Drupal::entityTypeManager()->getStorage('node')->load((int) $parts[1]);
    }
  }

  // Fallback: search menu_link_content by title.
  if ($menu_title) {
    $links = \Drupal::entityTypeManager()
      ->getStorage('menu_link_content')
      ->loadByProperties(['title' => $menu_title]);
    foreach ($links as $link) {
      $uri = $link->link->uri ?? '';
      if (str_starts_with($uri, 'entity:node/')) {
        $nid = (int) str_replace('entity:node/', '', $uri);
        $node = \Drupal::entityTypeManager()->getStorage('node')->load($nid);
        if ($node) {
          return $node;
        }
      }
    }
  }

  \Drupal::logger('site_page_builder')->warning(
    'Could not locate node for alias @alias — skipping layout setup.',
    ['@alias' => $alias]
  );
  return NULL;
}

/**
 * Returns a new UUID string.
 */
function _site_page_builder_uuid(): string {
  return \Drupal::service('uuid')->generate();
}

/**
 * Programmatically builds the About Us page Layout Builder sections.
 */
function _site_page_builder_setup_about_us_page(): void {
  $node = _site_page_builder_get_node_from_alias('/about-us', 'About us');
  if (!$node) {
    return;
  }

  /** @var \Drupal\layout_builder\Field\LayoutSectionItemList $layout_field */
  $layout_field = $node->get('layout_builder__layout');

  if (!$layout_field->isEmpty()) {
    \Drupal::logger('site_page_builder')->info(
      'About Us node @nid already has layout sections — skipping.',
      ['@nid' => $node->id()]
    );
    return;
  }

  // -------------------------------------------------------------------
  // Section 1 — Hero (1 column, full width)
  // -------------------------------------------------------------------
  $hero_uuid = _site_page_builder_uuid();
  $hero_component = new SectionComponent(
    $hero_uuid,
    'content',
    [
      'id'            => 'site_page_builder_hero_slider',
      'label'         => 'About Us Hero',
      'label_display' => FALSE,
      'image_url'     => '',
      'title'         => 'About Our Company',
      'subtitle'      => 'We are a creative team dedicated to building innovative digital solutions that drive growth and make a difference.',
      'button_text'   => 'Learn More',
      'button_link'   => '#story',
    ]
  );
  $section1 = new Section(
    'layout_onecol',
    ['column_widths' => ''],
    [$hero_uuid => $hero_component]
  );

  // -------------------------------------------------------------------
  // Section 2 — Company Story (2 columns: image left, text right)
  // These are inline_block placeholders. Editors populate content via
  // the Layout Builder UI using the "Add block" affordance.
  // -------------------------------------------------------------------
  $story_img_uuid = _site_page_builder_uuid();
  $story_img_component = new SectionComponent(
    $story_img_uuid,
    'first',
    [
      'id'            => 'inline_block:basic',
      'label'         => 'Company Image',
      'label_display' => FALSE,
      'view_mode'     => 'full',
    ]
  );

  $story_text_uuid = _site_page_builder_uuid();
  $story_text_component = new SectionComponent(
    $story_text_uuid,
    'second',
    [
      'id'            => 'inline_block:basic',
      'label'         => 'Company Story',
      'label_display' => FALSE,
      'view_mode'     => 'full',
    ]
  );

  $section2 = new Section(
    'layout_twocol_section',
    ['column_widths' => '50-50'],
    [
      $story_img_uuid  => $story_img_component,
      $story_text_uuid => $story_text_component,
    ]
  );

  // -------------------------------------------------------------------
  // Section 3 — Statistics Counter (4 equal columns)
  // -------------------------------------------------------------------
  $counter_data = [
    'first'  => ['icon' => 'fa-solid fa-briefcase', 'number' => '250+', 'counter_label' => 'Projects Completed'],
    'second' => ['icon' => 'fa-solid fa-users',     'number' => '120+', 'counter_label' => 'Happy Clients'],
    'third'  => ['icon' => 'fa-solid fa-circle-check', 'number' => '8+', 'counter_label' => 'Years of Experience'],
    'fourth' => ['icon' => 'fa-solid fa-globe',     'number' => '15',   'counter_label' => 'Countries Served'],
  ];

  $counter_components = [];
  foreach ($counter_data as $region => $data) {
    $uuid = _site_page_builder_uuid();
    $counter_components[$uuid] = new SectionComponent(
      $uuid,
      $region,
      [
        'id'             => 'site_page_builder_counter_item',
        'label'          => $data['counter_label'],
        'label_display'  => FALSE,
        'icon'           => $data['icon'],
        'number'         => $data['number'],
        'counter_label'  => $data['counter_label'],
      ]
    );
  }

  $section3 = new Section(
    'site_page_builder_fourcol',
    [],
    $counter_components
  );

  // -------------------------------------------------------------------
  // Section 4 — Call to Action (1 column, blue background)
  // -------------------------------------------------------------------
  $cta_uuid = _site_page_builder_uuid();
  $cta_component = new SectionComponent(
    $cta_uuid,
    'content',
    [
      'id'            => 'site_page_builder_call_to_action',
      'label'         => "CTA — Let's Build Something Great",
      'label_display' => FALSE,
      'title'         => "Let's Build Something Great Together",
      'subtitle'      => "We're ready to help you turn your ideas into reality with creativity and technology.",
      'button_text'   => 'Contact Us',
      'button_link'   => '/contact-us',
      'bg_color'      => '#2563EB',
    ]
  );
  $section4 = new Section(
    'layout_onecol',
    ['column_widths' => ''],
    [$cta_uuid => $cta_component]
  );

  // Append all sections.
  $layout_field->appendSection($section1);
  $layout_field->appendSection($section2);
  $layout_field->appendSection($section3);
  $layout_field->appendSection($section4);

  $node->save();

  \Drupal::logger('site_page_builder')->info(
    'About Us page layout built on node @nid.',
    ['@nid' => $node->id()]
  );
}

/**
 * Programmatically builds the Contact Us page Layout Builder sections.
 */
function _site_page_builder_setup_contact_us_page(): void {
  $node = _site_page_builder_get_node_from_alias('/contact-us', 'Contact Us');
  if (!$node) {
    return;
  }

  /** @var \Drupal\layout_builder\Field\LayoutSectionItemList $layout_field */
  $layout_field = $node->get('layout_builder__layout');

  if (!$layout_field->isEmpty()) {
    \Drupal::logger('site_page_builder')->info(
      'Contact Us node @nid already has layout sections — skipping.',
      ['@nid' => $node->id()]
    );
    return;
  }

  // -------------------------------------------------------------------
  // Section 1 — Hero (1 column, no button)
  // -------------------------------------------------------------------
  $hero_uuid = _site_page_builder_uuid();
  $hero_component = new SectionComponent(
    $hero_uuid,
    'content',
    [
      'id'            => 'site_page_builder_hero_slider',
      'label'         => 'Contact Us Hero',
      'label_display' => FALSE,
      'image_url'     => '',
      'title'         => 'Contact Us',
      'subtitle'      => "We'd love to hear from you. Reach out to us using the form or contact details below.",
      'button_text'   => '',
      'button_link'   => '',
    ]
  );
  $section1 = new Section(
    'layout_onecol',
    ['column_widths' => ''],
    [$hero_uuid => $hero_component]
  );

  // -------------------------------------------------------------------
  // Section 2 — Two columns: Contact Info (left) + Webform (right)
  // -------------------------------------------------------------------
  $contact_uuid = _site_page_builder_uuid();
  $contact_component = new SectionComponent(
    $contact_uuid,
    'first',
    [
      'id'                => 'site_page_builder_contact_info',
      'label'             => 'Contact Information',
      'label_display'     => FALSE,
      'address'           => "123 Business Street\nCity, Country 12345",
      'email'             => 'hello@yoursite.com',
      'phone'             => '+1 (123) 456-7890',
      'business_hours'    => "Monday - Friday\n9:00 AM - 6:00 PM (EST)",
      'show_social_links' => TRUE,
    ]
  );

  $webform_uuid = _site_page_builder_uuid();
  $webform_component = new SectionComponent(
    $webform_uuid,
    'second',
    [
      'id'            => 'webform_block',
      'label'         => 'Contact Us Form',
      'label_display' => FALSE,
      'webform_id'    => 'contact_us_form',
      'default_data'  => '',
      'redirect'      => FALSE,
      'lazy'          => FALSE,
    ]
  );

  $section2 = new Section(
    'layout_twocol_section',
    ['column_widths' => '33-67'],
    [
      $contact_uuid => $contact_component,
      $webform_uuid => $webform_component,
    ]
  );

  $layout_field->appendSection($section1);
  $layout_field->appendSection($section2);

  $node->save();

  \Drupal::logger('site_page_builder')->info(
    'Contact Us page layout built on node @nid.',
    ['@nid' => $node->id()]
  );
}
